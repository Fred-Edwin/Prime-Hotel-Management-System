# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# demo-video production scratch (Remotion project, screenshots) — not
# part of the app, has its own package.json/deps that must never be
# picked up by this project's build or type-check
docs/demo/source-v2/
docs/screenshots/
docs/demo/*.mp4
docs/demo/HANDOFF.md
docs/demo/treatment.md
docs/demo/screens/

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase
supabase/.branches
supabase/.temp
supabase/.env

# claude code local runtime state — but keep committed project skills and
# the verify-tooling *config* (not its downloaded output, see the nested
# .claude/tools/.gitignore) so future sessions inherit them from the repo
# instead of re-deriving/reinstalling from scratch every time.
.claude/*
!.claude/skills/
!.claude/tools/
